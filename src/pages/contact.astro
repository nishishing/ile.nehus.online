---
import BaseLayout from "~layouts/BaseLayout.astro";
import PageHero from "~components/PageHero.astro";
import { breadcrumbSchema, jsonLd } from "~lib/schema";
import { site } from "~data/site";

const description = `iLe（${site.companyName}）へのお問い合わせ。取材・採用・提携・取材依頼など、各種お問い合わせを受け付けています。`;

const pageSchemas = [
  breadcrumbSchema([
    { name: "Home", url: "/" },
    { name: "Contact", url: "/contact" },
  ]),
];

const channels = [
  {
    label: "General Inquiries",
    title: "一般お問い合わせ",
    desc: "ブランド、お知らせ、取材・メディア掲載に関するお問い合わせ",
    target: site.contactEmail,
  },
  {
    label: "Recruit",
    title: "採用・キャリアに関するお問い合わせ",
    desc: "美容師・アシスタント・新卒採用のご相談",
    target: site.contactEmail,
  },
  {
    label: "Partnership",
    title: "サロン導入・提携",
    desc: "プロダクト導入のご相談・提携のご相談",
    target: site.contactEmail,
  },
];
---

<BaseLayout title="Contact" description={description}>
  <Fragment slot="head">
    {pageSchemas.map((schema) => (
      <script type="application/ld+json" set:html={jsonLd(schema)} is:inline />
    ))}
  </Fragment>

  <PageHero
    eyebrow="— Get in Touch"
    title="CONTACT"
  />

  <section class="contact-section">
    <p class="contact-lede">
      iLe へのお問い合わせは、下記のチャネルからお願いいたします。<br />
      <em>For all inquiries, please reach out via the channels below.</em>
    </p>

    <div class="contact-channels">
      {channels.map((c, i) => (
        <article class="contact-channel">
          <p class="contact-channel__label">/ {String(i + 1).padStart(2, "0")} &nbsp; {c.label}</p>
          <h2 class="contact-channel__title">{c.title}</h2>
          <p class="contact-channel__desc">{c.desc}</p>
          <a class="contact-channel__email" href={`mailto:${c.target}`}>
            {c.target} →
          </a>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  .contact-section {
    padding: 110px 32px 140px;
    max-width: 1100px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }
  .contact-lede {
    font-family: var(--font-display);
    font-style: italic;
    font-size: clamp(16px, 1.6vw, 20px);
    line-height: 1.8;
    text-align: center;
    color: var(--color-fg-muted);
    margin: 0 0 80px;
  }
  .contact-lede em {
    display: block;
    margin-top: 0.4em;
    font-size: 0.85em;
    color: var(--color-fg-subtle);
  }
  .contact-channels {
    display: grid;
    gap: 0;
    border-top: 1px solid var(--color-border);
  }
  .contact-channel {
    padding: 48px 0;
    border-bottom: 1px solid var(--color-border);
    display: grid;
    grid-template-columns: 1fr 1.5fr;
    gap: 48px;
    align-items: baseline;
  }
  @media (max-width: 700px) {
    .contact-channel {
      grid-template-columns: 1fr;
      gap: 18px;
    }
  }
  .contact-channel__label {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--color-fg-muted);
    margin: 0;
  }
  .contact-channel__title {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(22px, 2.5vw, 30px);
    line-height: 1.3;
    margin: 0 0 14px;
  }
  .contact-channel__desc {
    font-size: 14px;
    line-height: 1.85;
    color: var(--color-fg-muted);
    margin: 0 0 24px;
  }
  .contact-channel__email {
    font-family: var(--font-mono);
    font-size: 13px;
    letter-spacing: 0.18em;
    border-bottom: 1px solid var(--color-fg);
    padding-bottom: 2px;
    display: inline-block;
    word-break: break-all;
  }
</style>
