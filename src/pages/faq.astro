---
import BaseLayout from "~layouts/BaseLayout.astro";
import PageHero from "~components/PageHero.astro";
import {
  faqPageSchema,
  breadcrumbSchema,
  jsonLd,
} from "~lib/schema";
import { getFaqItems } from "~lib/content";

const description =
  "iLe（イル）と株式会社ing についてのよくある質問。ブランド、サロン、エフェクトブリーチやバレイヤージュなどの技術、採用に関するご質問にお答えします。";

const faqItems = await getFaqItems();

const pageSchemas = [
  faqPageSchema([...faqItems]),
  breadcrumbSchema([
    { name: "Home", url: "/" },
    { name: "FAQ", url: "/faq" },
  ]),
];

const categories = [
  { id: "brand", label: "Brand" },
  { id: "salon", label: "Salons" },
  { id: "technique", label: "Technique" },
  { id: "recruit", label: "Recruit" },
];

const groupedFaq = categories.map((cat) => ({
  ...cat,
  items: faqItems.filter((q) => q.category === cat.id),
}));
---

<BaseLayout title="FAQ" description={description}>
  <Fragment slot="head">
    {pageSchemas.map((schema) => (
      <script type="application/ld+json" set:html={jsonLd(schema)} is:inline />
    ))}
  </Fragment>

  <PageHero
    eyebrow="— Frequently Asked"
    title="FAQ"
  />

  <section class="faq-section">
    {groupedFaq.map((group) => (
      <div class="faq-group">
        <h2 class="faq-group__title">
          <span class="faq-group__title-num">/ {String(categories.findIndex((c) => c.id === group.id) + 1).padStart(2, "0")}</span>
          {group.label}
        </h2>
        <dl class="faq-list">
          {group.items.map((item) => (
            <div class="faq-item">
              <dt class="faq-item__q">
                <span class="faq-item__q-mark">Q.</span>
                {item.question}
              </dt>
              <dd class="faq-item__a">{item.answer}</dd>
            </div>
          ))}
        </dl>
      </div>
    ))}
  </section>
</BaseLayout>

<style>
  .faq-section {
    padding: 110px 32px 140px;
    max-width: 980px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }
  .faq-group {
    margin-bottom: 100px;
  }
  .faq-group__title {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(28px, 4vw, 48px);
    line-height: 1;
    letter-spacing: 0.02em;
    text-transform: uppercase;
    margin: 0 0 48px;
    display: flex;
    align-items: baseline;
    gap: 16px;
  }
  .faq-group__title-num {
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--color-fg-muted);
  }

  .faq-list {
    margin: 0;
    border-top: 1px solid var(--color-border);
  }
  .faq-item {
    padding: 32px 0;
    border-bottom: 1px solid var(--color-border);
  }
  .faq-item__q {
    margin: 0 0 18px;
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(18px, 2vw, 24px);
    line-height: 1.5;
    display: grid;
    grid-template-columns: 40px 1fr;
    gap: 16px;
    align-items: baseline;
  }
  .faq-item__q-mark {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.28em;
    color: var(--color-fg-muted);
  }
  .faq-item__a {
    margin: 0;
    padding-left: 56px;
    font-size: 15px;
    line-height: 2;
    color: var(--color-fg-muted);
  }
  @media (max-width: 640px) {
    .faq-item__a {
      padding-left: 0;
    }
  }
</style>
