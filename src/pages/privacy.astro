---
import BaseLayout from "~layouts/BaseLayout.astro";
import PageHero from "~components/PageHero.astro";
import { breadcrumbSchema, jsonLd } from "~lib/schema";
import { site } from "~data/site";

const description = `美容室 iLe を運営する ${site.companyName} のプライバシーポリシー。お客様の個人情報の取得・利用目的・管理・第三者提供・お問い合わせ窓口についての取り扱いを定めています。`;

const pageSchemas = [
  breadcrumbSchema([
    { name: "Home", url: "/" },
    { name: "Privacy Policy", url: "/privacy" },
  ]),
];
---

<BaseLayout title="Privacy Policy" description={description} noindex={false}>
  <Fragment slot="head">
    {pageSchemas.map((schema) => (
      <script type="application/ld+json" set:html={jsonLd(schema)} is:inline />
    ))}
  </Fragment>

  <PageHero
    eyebrow="— Legal"
    title="PRIVACY POLICY"
  />

  <article class="legal-article">
    <h2>1. 個人情報の利用目的</h2>
    <p>
      {site.companyName}（以下「当社」といいます）は、お問い合わせ、サービスの提供、採用応募の処理、その他正当な業務遂行のために必要な範囲でお客様の個人情報を利用いたします。
    </p>

    <h2>2. 個人情報の管理</h2>
    <p>
      当社は、お客様の個人情報を正確かつ最新の状態に保ち、個人情報への不正アクセス・紛失・破壊・改ざん・漏洩などを防止するため、必要かつ適切な安全対策を講じます。
    </p>

    <h2>3. 個人情報の第三者提供</h2>
    <p>
      当社は、法令に基づく場合または正当な理由がある場合を除き、お客様の同意を得ることなく個人情報を第三者に提供することはありません。
    </p>

    <h2>4. 個人情報の開示・訂正・削除</h2>
    <p>
      お客様ご本人から個人情報の開示・訂正・削除のご要望があった場合、本人確認の上、合理的な範囲で速やかに対応いたします。
    </p>

    <h2>5. お問い合わせ</h2>
    <p>
      個人情報の取り扱いに関するお問い合わせは下記までお願いいたします。<br />
      <a href={`mailto:${site.contactEmail}`}>{site.contactEmail}</a>
    </p>

    <h2>6. 改定について</h2>
    <p>
      本ポリシーは、法令の変更等により予告なく改定されることがあります。最新版は本ページにて公開いたします。
    </p>

    <p class="legal-article__meta">
      制定日：2026年8月1日<br />
      {site.companyName}（{site.companyNameLatin}）
    </p>
  </article>
</BaseLayout>

<style>
  .legal-article {
    max-width: 720px;
    margin: 0 auto;
    padding: 110px 32px 140px;
    position: relative;
    z-index: 1;
    font-size: 15px;
    line-height: 2;
    color: var(--color-fg);
  }
  .legal-article h2 {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(20px, 2.2vw, 26px);
    line-height: 1.4;
    margin: 2.4em 0 0.6em;
    text-transform: uppercase;
    letter-spacing: 0.01em;
  }
  .legal-article p {
    margin: 1em 0;
    color: var(--color-fg-muted);
  }
  .legal-article a {
    border-bottom: 1px solid var(--color-fg);
    padding-bottom: 1px;
  }
  .legal-article__meta {
    margin-top: 4em;
    padding-top: 2em;
    border-top: 1px solid var(--color-border);
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-fg-subtle);
  }
</style>
