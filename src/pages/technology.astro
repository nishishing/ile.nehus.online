---
import BaseLayout from "~layouts/BaseLayout.astro";
import PageHero from "~components/PageHero.astro";
import { breadcrumbSchema, jsonLd } from "~lib/schema";

const description =
  "iLe の技術 — エフェクトブリーチ、再現性レイヤーカット、ハイトーン・ヘアエステ。髪の芯を残し、ダメージを抑えながらデザインする独自のロジック。";

const pillars = [
  {
    n: "01",
    h: "エフェクトブリーチ",
    sub: "Effect Bleach",
    points: [
      "ダメージ履歴を10段階で診断し、過酸化水素濃度をミリ単位で使い分ける精密な薬剤選定（パーソナル減力）。",
      "酸化重合を最適化し、残留物質を除去。発色・色持ち・色落ちの美しさまで設計する。",
    ],
    link: "/effect-bleach",
  },
  {
    n: "02",
    h: "再現性レイヤーカット",
    sub: "Layer Cut",
    points: [
      "「360度骨格補正デザイン」で、小顔効果と首のラインを引き立てる。",
      "「質感調整（スライドカット）」でパサつきを抑え、ハイトーンの動きを美しく見せる。",
    ],
  },
  {
    n: "03",
    h: "ハイトーン・ヘアエステ",
    sub: "Hair Esthe",
    points: [
      "pHバランスの正常化 — アルカリに傾いた髪を速やかに弱酸性へ戻す。",
      "超音波トリートメント — ケラチンと脂質を髪の深部まで補給する。",
    ],
  },
];

const pageSchemas = [
  breadcrumbSchema([
    { name: "Home", url: "/" },
    { name: "Technology", url: "/technology" },
  ]),
];
---

<BaseLayout title="Technology — iLe の技術" description={description}>
  <Fragment slot="head">
    {pageSchemas.map((schema) => (
      <script type="application/ld+json" set:html={jsonLd(schema)} is:inline />
    ))}
  </Fragment>

  <PageHero
    eyebrow="— iLe Technology"
    title="TECHNOLOGY"
    italicTitle="Technology"
  />

  <section class="tech-lead">
    <p class="tech-lead__text">
      髪の<em>「芯」</em>を残し、素材を守りながらデザインする——iLe の技術は、感覚ではなく再現性のあるロジックに基づいています。ブリーチ・カット・ケアの三本柱で、一生続けられるハイトーンを支えます。
    </p>
  </section>

  <section class="tech-pillars">
    {pillars.map((p) => (
      <article class="tech-pillar">
        <div class="tech-pillar__head">
          <span class="tech-pillar__n">{p.n}</span>
          <h2 class="tech-pillar__h">
            {p.h}<span>{p.sub}</span>
          </h2>
        </div>
        <div class="tech-pillar__body">
          <ul class="tech-pillar__points">
            {p.points.map((pt) => <li>{pt}</li>)}
          </ul>
          {p.link && (
            <a class="tech-pillar__link" href={p.link}>
              詳しく見る →
            </a>
          )}
        </div>
      </article>
    ))}
  </section>

  <section class="tech-related" aria-label="関連ページ">
    <p class="tech-related__lead">技術の詳細や、料金・スタッフもあわせてご覧ください。</p>
    <nav class="tech-related__links">
      <a href="/effect-bleach">エフェクトブリーチ</a>
      <a href="/menu">メニュー・料金</a>
      <a href="/stylists">スタイリスト</a>
      <a href="/faq">よくある質問</a>
    </nav>
  </section>
</BaseLayout>

<style>
  .tech-related {
    padding: 20px 32px 130px;
    max-width: 980px;
    margin: 0 auto;
    text-align: center;
    position: relative;
    z-index: 1;
  }
  .tech-related__lead {
    font-size: 14px;
    color: var(--color-fg-muted);
    margin: 0 0 24px;
  }
  .tech-related__links {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 10px 14px;
  }
  .tech-related__links a {
    font-family: var(--font-mono);
    font-size: 10.5px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-fg-muted);
    border: 1px solid var(--color-border);
    border-radius: 999px;
    padding: 8px 15px;
    transition: color 0.15s, border-color 0.15s;
  }
  .tech-related__links a:hover {
    color: var(--color-fg);
    border-color: var(--color-fg);
  }
  .tech-lead {
    padding: 100px 32px 40px;
    position: relative;
    z-index: 1;
  }
  .tech-lead__text {
    max-width: 720px;
    margin: 0 auto;
    font-size: 16px;
    line-height: 2;
    color: var(--color-fg-muted);
    text-align: center;
  }
  .tech-lead__text em {
    font-style: italic;
    color: var(--color-fg);
  }

  .tech-pillars {
    padding: 40px 32px 140px;
    max-width: 880px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }
  .tech-pillar {
    display: grid;
    grid-template-columns: 1fr;
    gap: 20px;
    padding: 48px 0;
    border-top: 1px solid var(--color-mist);
  }
  .tech-pillar:last-child {
    border-bottom: 1px solid var(--color-mist);
  }
  @media (min-width: 760px) {
    .tech-pillar {
      grid-template-columns: 300px 1fr;
      gap: 48px;
    }
  }
  .tech-pillar__n {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.28em;
    color: var(--color-fg-muted);
    display: block;
    margin-bottom: 14px;
  }
  .tech-pillar__h {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: 26px;
    line-height: 1.3;
    margin: 0;
  }
  .tech-pillar__h span {
    display: block;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: var(--color-fg-muted);
    margin-top: 8px;
  }
  .tech-pillar__points {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .tech-pillar__points li {
    font-size: 15px;
    line-height: 1.9;
    color: var(--color-fg-muted);
    padding-left: 20px;
    position: relative;
    margin-bottom: 1em;
  }
  .tech-pillar__points li::before {
    content: "—";
    position: absolute;
    left: 0;
    color: var(--color-ash);
  }
  .tech-pillar__link {
    display: inline-block;
    margin-top: 8px;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    border-bottom: 1px solid var(--color-fg-muted);
    padding-bottom: 2px;
  }
</style>
