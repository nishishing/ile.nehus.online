---
import BaseLayout from "~layouts/BaseLayout.astro";
import PageHero from "~components/PageHero.astro";
import { navPrimary } from "~data/site";

const description =
  "お探しのページは見つかりませんでした。iLe（イル）— 原宿・名古屋・長岡の美容室。";
---

<BaseLayout title="404 — Not Found" description={description} noindex={true}>
  <PageHero eyebrow="— Error 404" title="NOT FOUND" />

  <section class="notfound">
    <p class="notfound__lead">
      お探しのページは見つかりませんでした。<br />
      <em>The page you are looking for could not be found.</em>
    </p>

    <nav class="notfound__nav" aria-label="主要ページ">
      <a href="/">Home</a>
      {navPrimary.map((item) => (
        <a href={item.href} set:html={item.label} />
      ))}
    </nav>
  </section>
</BaseLayout>

<style>
  .notfound {
    padding: 110px 32px 160px;
    max-width: 760px;
    margin: 0 auto;
    text-align: center;
    position: relative;
    z-index: 1;
  }
  .notfound__lead {
    font-family: var(--font-display);
    font-size: clamp(18px, 2vw, 24px);
    line-height: 1.8;
    color: var(--color-fg);
    margin: 0 0 56px;
  }
  .notfound__lead em {
    font-style: italic;
    font-size: 0.8em;
    color: var(--color-fg-muted);
    display: block;
    margin-top: 0.6em;
  }
  .notfound__nav {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 14px 28px;
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
  }
  .notfound__nav a {
    color: var(--color-fg-muted);
    border-bottom: 1px solid transparent;
    padding-bottom: 2px;
    transition: color 0.15s, border-color 0.15s;
  }
  .notfound__nav a:hover {
    color: var(--color-fg);
    border-bottom-color: var(--color-fg);
  }
</style>
