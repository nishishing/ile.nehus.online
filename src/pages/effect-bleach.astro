---
import BaseLayout from "~layouts/BaseLayout.astro";
import PageHero from "~components/PageHero.astro";
import Picture from "~components/Picture.astro";
import { site } from "~data/site";
import {
  breadcrumbSchema,
  definedTermSchema,
  jsonLd,
} from "~lib/schema";

const description =
  "エフェクトブリーチは、iLe（共同代表・酒井元樹）が開発・体系化した独自のブリーチ技術。ダメージ履歴を10段階で診断し過酸化水素濃度をミリ単位で使い分ける精密な薬剤選定で、髪の『芯』を残したまま透明感のあるハイトーンを実現する。日本のブリーチ業界に革命を起こした技術として知られる。";

// The three principles (from iLe's official technique documentation)
const principles = [
  {
    h: "複雑な履歴を読み解く",
    t: "黒染めやセルフカラーが重なった髪でも、残留色素を一つずつ見極め、最小限の負担で理想へ近づける。",
  },
  {
    h: "「ブリーチ＝痛む」を覆す",
    t: "傷むことを前提にしない。艶と手触りを保ったまま、狙いどおりのハイトーンへ導く。",
  },
  {
    h: "数ヶ月先まで設計する",
    t: "その日の仕上がりで終わらせない。色落ちの過程まで計算し、数ヶ月先の美しさから逆算して描く。",
  },
];

// Customer voices (from the existing site's reviews)
const voices = [
  "独自のエフェクトブリーチで、驚くほどサラサラな仕上がりになりました。",
  "ブリーチ特有のパサつきがなく、艶と透明感に大満足です。",
  "色の抜け方が本当に綺麗で、色落ちしてもムラになりません。",
];

// Menu (price guide carried over from the existing site; tax/■店舗により変動の可能性)
const menu = [
  { name: "エフェクトブリーチ ＋ カラー（全頭）", price: "¥18,700〜" },
  { name: "ダブルエフェクトブリーチ（2回）＋ カラー", price: "¥25,300〜" },
  { name: "ケアブリーチ（リタッチ）＋ カラー", price: "¥16,500〜" },
  { name: "カット ＋ エフェクトブリーチ ＋ カラー", price: "¥24,200〜" },
];

// Style gallery — real Effect Bleach / color work from the salons' own Hot
// Pepper galleries, self-hosted + a low-saturation cool grade (cool-mono lean
// while keeping the colour legible, since the colour *is* the work).
const gallery = [
  { src: "/gallery/01.jpg", tag: "ミルクティーインナーカラー" },
  { src: "/gallery/02.jpg", tag: "ブリーチ / レイヤーカット" },
  { src: "/gallery/03.jpg", tag: "ミルクティーベージュ" },
  { src: "/gallery/04.jpg", tag: "デザインカラー / フェイスフレーミング" },
  { src: "/gallery/05.jpg", tag: "ブリーチ / ミディアム" },
  { src: "/gallery/06.jpg", tag: "バタフライレイヤー" },
  { src: "/gallery/07.jpg", tag: "ミルクティーブロンド" },
  { src: "/gallery/08.jpg", tag: "ハイトーンダブルカラー" },
  { src: "/gallery/09.jpg", tag: "チェリーレッド / バーガンディ" },
  { src: "/gallery/10.jpg", tag: "ココアベージュ" },
  { src: "/gallery/11.jpg", tag: "オレンジベージュ" },
  { src: "/gallery/12.jpg", tag: "ブロンド / 抜きっぱなし" },
];

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "@id": `${site.url}/effect-bleach#service`,
  name: "エフェクトブリーチ",
  alternateName: "Effect Bleach",
  serviceType: "ヘアブリーチ / ハイトーンカラー",
  provider: { "@id": `${site.url}/#organization` },
  areaServed: "JP",
  url: `${site.url}/effect-bleach`,
  description,
};

const gallerySchema = {
  "@context": "https://schema.org",
  "@type": "ImageGallery",
  name: "Effect Bleach — Works",
  about: { "@id": `${site.url}/effect-bleach#service` },
  associatedMedia: gallery.map((g) => ({
    "@type": "ImageObject",
    contentUrl: `${site.url}${g.src}`,
    caption: g.tag,
  })),
};

const pageSchemas = [
  serviceSchema,
  gallerySchema,
  definedTermSchema({
    term: "エフェクトブリーチ",
    pronunciation: "エフェクトブリーチ / Effect Bleach",
    definition: description,
  }),
  breadcrumbSchema([
    { name: "Home", url: "/" },
    { name: "Effect Bleach", url: "/effect-bleach" },
  ]),
];
---

<BaseLayout title="Effect Bleach — エフェクトブリーチ" description={description}>
  <Fragment slot="head">
    {pageSchemas.map((schema) => (
      <script type="application/ld+json" set:html={jsonLd(schema)} is:inline />
    ))}
  </Fragment>

  <PageHero
    eyebrow="— iLe Signature Technique"
    title="EFFECT BLEACH"
    italicTitle="Bleach"
  />

  <section class="eb-lead">
    <div class="eb-lead__inner">
      <p class="eb-lead__statement">
        一生続けられる <em>ハイトーン</em> を、<br />原宿から全国へ。
      </p>
      <p class="eb-lead__text">
        <strong>エフェクトブリーチ</strong>は、iLe 共同代表・<a href="/stylists/sakai-motoki">酒井 元樹</a>が開発・体系化した独自のブリーチ技術です。髪の<em>「芯」</em>を残し、素材を守りながらデザインする——その哲学から生まれました。
      </p>
      <p class="eb-lead__text">
        従来のブリーチが「いかに色を抜くか」を追求するのに対し、エフェクトブリーチは<em>髪体力を残したまま透明感を引き出すこと</em>を起点に設計します。ダメージ前提だったハイトーンの常識を塗り替え、いまや日本のブリーチシーンの原点と称されています。
      </p>
    </div>
  </section>

  <section class="eb-principles" aria-labelledby="eb-principles-h">
    <h2 id="eb-principles-h" class="eb-section-h">Three Principles</h2>
    <div class="eb-principles__grid">
      {principles.map((p, i) => (
        <div class="eb-principle">
          <span class="eb-principle__num">{String(i + 1).padStart(2, "0")}</span>
          <h3 class="eb-principle__h">{p.h}</h3>
          <p class="eb-principle__t">{p.t}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="eb-logic" aria-labelledby="eb-logic-h">
    <div class="eb-logic__inner">
      <h2 id="eb-logic-h" class="eb-section-h eb-section-h--left">The Logic</h2>
      <div class="eb-logic__row">
        <h3 class="eb-logic__h">精密な薬剤選定<br /><span>パーソナル減力</span></h3>
        <p class="eb-logic__t">
          根元・中間・毛先のダメージ履歴を <strong>10段階</strong>で診断。
          <strong>5種類</strong>の過酸化水素濃度をミリ単位で使い分けることで、
          断毛リスクを最小限に抑えます。
        </p>
      </div>
      <div class="eb-logic__row">
        <h3 class="eb-logic__h">酸化重合の<br /><span>最適化</span></h3>
        <p class="eb-logic__t">
          オンカラーの発色を妨げる残留物質を除去。発色と色持ち、そして
          <em>色落ちの美しさ</em>までを設計に含めます。
        </p>
      </div>
    </div>
  </section>

  <section class="eb-voices" aria-label="Customer voices">
    <div class="eb-voices__grid">
      {voices.map((v) => (
        <blockquote class="eb-voice">“{v}”</blockquote>
      ))}
    </div>
  </section>

  <section class="eb-gallery" aria-labelledby="eb-gallery-h">
    <div class="eb-gallery__inner">
      <h2 id="eb-gallery-h" class="eb-section-h">Works</h2>
      <p class="eb-gallery__lead">
        エフェクトブリーチによる作例。— <em>透明感</em>と<em>色落ちの美しさ</em>を、実際のデザインで。
      </p>
      <div class="eb-gallery__grid">
        {gallery.map((g) => (
          <figure class="eb-shot">
            <Picture
              class="eb-shot__img"
              src={g.src}
              width="600"
              height="800"
              alt={`エフェクトブリーチの作例 — ${g.tag}`}
              loading="lazy"
            />
            <figcaption class="eb-shot__cap">{g.tag}</figcaption>
          </figure>
        ))}
      </div>
    </div>
  </section>

  <section class="eb-menu" aria-labelledby="eb-menu-h">
    <div class="eb-menu__inner">
      <h2 id="eb-menu-h" class="eb-section-h">Menu</h2>
      <dl class="eb-menu__list">
        {menu.map((m) => (
          <div class="eb-menu__row">
            <dt>{m.name}</dt>
            <dd>{m.price}</dd>
          </div>
        ))}
      </dl>
      <p class="eb-menu__note">
        — 料金は目安です。最新の価格・所要時間は各店の Hot Pepper Beauty をご確認ください。
      </p>
    </div>
  </section>

  <section class="eb-academy">
    <div class="eb-academy__inner">
      <h2 class="eb-section-h">iLe Academy</h2>
      <p class="eb-academy__text">
        エフェクトブリーチの理論は、<strong>iLe Academy</strong> を通じて全国の美容師へ開かれています。基礎から実践までを体系立てて学べる場を整え、酒井 元樹・西村 涼は国内外で講師を務めてきました。<em>プロを教えるプロ</em>として、業界全体の底上げを牽引しています。
      </p>
      <p class="eb-academy__text eb-academy__book">
        共著『複雑履歴のブリーチ大全』（酒井 元樹・西村 涼）— <a href="https://www.amazon.co.jp/dp/4908697507" target="_blank" rel="noopener">Amazon で見る →</a>
      </p>
    </div>
  </section>

  <section class="eb-where">
    <div class="eb-where__inner">
      <h2 class="eb-where__h">Where to experience</h2>
      <p class="eb-where__text">
        エフェクトブリーチは、<strong>Effect ブリーチアンバサダー</strong>をはじめとするスタイリストが、原宿・名古屋・長岡の全 iLe 店舗で対応しています。
      </p>
      <div class="eb-where__links">
        <a href="/salons">店舗一覧を見る →</a>
        <a href="/stylists">スタイリストを見る →</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .eb-section-h {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(28px, 3.5vw, 44px);
    text-transform: uppercase;
    text-align: center;
    margin: 0 0 56px;
  }
  .eb-section-h--left {
    text-align: left;
  }

  .eb-lead {
    padding: 110px 32px;
    position: relative;
    z-index: 1;
  }
  .eb-lead__inner {
    max-width: 760px;
    margin: 0 auto;
  }
  .eb-lead__statement {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(28px, 4.5vw, 52px);
    line-height: 1.3;
    text-transform: uppercase;
    text-align: center;
    margin: 0 0 56px;
  }
  .eb-lead__statement em {
    font-style: italic;
  }
  .eb-lead__text {
    font-size: 16px;
    line-height: 2;
    color: var(--color-fg-muted);
    margin: 0 0 1.6em;
  }
  .eb-lead__text em {
    font-style: italic;
    color: var(--color-fg);
  }
  .eb-lead__text a {
    border-bottom: 1px solid var(--color-fg-muted);
    padding-bottom: 1px;
  }
  .eb-lead__text strong {
    font-weight: 700;
    color: var(--color-fg);
  }

  .eb-principles {
    padding: 110px 32px;
    background: var(--color-pearl);
    position: relative;
    z-index: 1;
  }
  .eb-principles__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 40px;
    max-width: 1000px;
    margin: 0 auto;
  }
  @media (min-width: 860px) {
    .eb-principles__grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
  .eb-principle__num {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.28em;
    color: var(--color-fg-muted);
    display: block;
    margin-bottom: 18px;
  }
  .eb-principle__h {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: 22px;
    margin: 0 0 12px;
    line-height: 1.4;
  }
  .eb-principle__t {
    font-size: 14px;
    line-height: 1.9;
    color: var(--color-fg-muted);
    margin: 0;
  }

  .eb-logic {
    padding: 110px 32px;
    position: relative;
    z-index: 1;
  }
  .eb-logic__inner {
    max-width: 880px;
    margin: 0 auto;
  }
  .eb-logic__row {
    display: grid;
    grid-template-columns: 1fr;
    gap: 16px;
    padding: 36px 0;
    border-top: 1px solid var(--color-mist);
  }
  .eb-logic__row:last-child {
    border-bottom: 1px solid var(--color-mist);
  }
  @media (min-width: 760px) {
    .eb-logic__row {
      grid-template-columns: 280px 1fr;
      gap: 40px;
    }
  }
  .eb-logic__h {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: 24px;
    line-height: 1.4;
    margin: 0;
  }
  .eb-logic__h span {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: var(--color-fg-muted);
    display: inline-block;
    margin-top: 8px;
  }
  .eb-logic__t {
    font-size: 15px;
    line-height: 2;
    color: var(--color-fg-muted);
    margin: 0;
  }
  .eb-logic__t strong {
    color: var(--color-fg);
    font-weight: 700;
  }
  .eb-logic__t em {
    font-style: italic;
    color: var(--color-fg);
  }

  .eb-voices {
    padding: 90px 32px;
    background: var(--color-ink);
    color: var(--color-white);
    position: relative;
    z-index: 1;
  }
  .eb-voices__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 36px;
    max-width: 1000px;
    margin: 0 auto;
  }
  @media (min-width: 860px) {
    .eb-voices__grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
  .eb-voice {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 18px;
    line-height: 1.7;
    margin: 0;
    color: var(--color-white);
  }

  .eb-gallery {
    padding: 110px 32px;
    background: var(--color-snow);
    position: relative;
    z-index: 1;
  }
  .eb-gallery__inner {
    max-width: 1200px;
    margin: 0 auto;
  }
  .eb-gallery__lead {
    text-align: center;
    font-size: 15px;
    line-height: 1.9;
    color: var(--color-fg-muted);
    margin: 0 0 48px;
  }
  .eb-gallery__lead em {
    font-family: var(--font-display);
    font-style: italic;
    color: var(--color-fg);
  }
  .eb-gallery__grid {
    display: grid;
    gap: 14px;
    grid-template-columns: repeat(2, 1fr);
  }
  @media (min-width: 700px) {
    .eb-gallery__grid { grid-template-columns: repeat(3, 1fr); }
  }
  @media (min-width: 1000px) {
    .eb-gallery__grid { grid-template-columns: repeat(4, 1fr); }
  }
  .eb-shot {
    margin: 0;
    position: relative;
    overflow: hidden;
    aspect-ratio: 3 / 4;
  }
  .eb-shot__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    filter: saturate(0.9) contrast(1.02);
    transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .eb-shot:hover .eb-shot__img {
    transform: scale(1.04);
  }
  .eb-shot__cap {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    padding: 22px 12px 10px;
    font-family: var(--font-mono);
    font-size: 9.5px;
    letter-spacing: 0.16em;
    color: #fff;
    background: linear-gradient(180deg, transparent, rgba(0, 0, 0, 0.6));
    opacity: 0;
    transition: opacity 0.4s ease;
  }
  .eb-shot:hover .eb-shot__cap {
    opacity: 1;
  }

  .eb-menu {
    padding: 110px 32px;
    position: relative;
    z-index: 1;
  }
  .eb-menu__inner {
    max-width: 720px;
    margin: 0 auto;
  }
  .eb-menu__list {
    margin: 0;
  }
  .eb-menu__row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 24px;
    padding: 22px 0;
    border-bottom: 1px solid var(--color-mist);
  }
  .eb-menu__row dt {
    font-size: 15px;
    line-height: 1.6;
  }
  .eb-menu__row dd {
    margin: 0;
    font-family: var(--font-mono);
    font-size: 14px;
    letter-spacing: 0.04em;
    white-space: nowrap;
    color: var(--color-fg);
  }
  .eb-menu__note {
    font-size: 12.5px;
    line-height: 1.8;
    color: var(--color-fg-subtle);
    margin: 24px 0 0;
  }

  .eb-academy {
    padding: 110px 32px;
    background: var(--color-pearl);
    position: relative;
    z-index: 1;
  }
  .eb-academy__inner {
    max-width: 720px;
    margin: 0 auto;
    text-align: center;
  }
  .eb-academy__text {
    font-size: 16px;
    line-height: 2;
    color: var(--color-fg-muted);
    margin: 0 0 1.4em;
  }
  .eb-academy__text strong {
    color: var(--color-fg);
    font-weight: 700;
  }
  .eb-academy__text em {
    font-style: italic;
    color: var(--color-fg);
  }
  .eb-academy__book {
    font-size: 14px;
  }
  .eb-academy__book a {
    border-bottom: 1px solid var(--color-fg-muted);
    padding-bottom: 1px;
  }

  .eb-where {
    padding: 110px 32px 140px;
    background: var(--color-ink);
    color: var(--color-white);
    position: relative;
    z-index: 1;
  }
  .eb-where__inner {
    max-width: 720px;
    margin: 0 auto;
    text-align: center;
  }
  .eb-where__h {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(26px, 3.5vw, 40px);
    text-transform: uppercase;
    margin: 0 0 28px;
  }
  .eb-where__text {
    font-size: 15px;
    line-height: 2;
    color: var(--color-fg-on-dark-muted);
    margin: 0 0 40px;
  }
  .eb-where__text strong {
    color: var(--color-white);
    font-weight: 500;
  }
  .eb-where__links {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 28px;
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
  }
  .eb-where__links a {
    color: var(--color-white);
    border-bottom: 1px solid var(--color-fg-on-dark-muted);
    padding-bottom: 2px;
  }
</style>
