---
import BaseLayout from "~layouts/BaseLayout.astro";
import PageHero from "~components/PageHero.astro";
import { breadcrumbSchema, jsonLd } from "~lib/schema";
import { site } from "~data/site";

const description = `iLe（${site.companyName}）の採用情報。美容師（スタイリスト・アシスタント）、新卒採用を募集しています。原宿・名古屋・長岡の4店舗で、共に島をつくる仲間を募集中。`;

const pageSchemas = [
  breadcrumbSchema([
    { name: "Home", url: "/" },
    { name: "Recruit", url: "/recruit" },
  ]),
];

const positions = [
  {
    label: "Stylist",
    title: "美容師（スタイリスト）",
    desc:
      "技術と感性を活かして、お客様一人ひとりと向き合えるスタイリストを募集しています。",
    target: ["原宿（×2）", "名古屋", "長岡"],
  },
  {
    label: "Assistant",
    title: "美容師（アシスタント）",
    desc:
      "iLe の島づくりを支える、技術と心を磨くアシスタントを募集しています。",
    target: ["原宿（×2）", "名古屋", "長岡"],
  },
  {
    label: "New Grad",
    title: "新卒採用",
    desc:
      "美容専門学校を卒業予定の方を対象とした新卒採用。基礎から共に学ぶ環境です。",
    target: ["全店舗"],
  },
];
---

<BaseLayout title="Recruit" description={description}>
  <Fragment slot="head">
    {pageSchemas.map((schema) => (
      <script type="application/ld+json" set:html={jsonLd(schema)} is:inline />
    ))}
  </Fragment>

  <PageHero
    eyebrow="— Join the Island"
    title="RECRUIT"
    italicTitle="Island"
  />

  <section class="recruit-intro">
    <p class="recruit-intro__lede">
      4つの島で、<em>新しい仲間</em> を募集しています。
    </p>
    <p class="recruit-intro__text">
      iLe は、原宿・名古屋・長岡で4店舗の美容室を運営する株式会社ing のブランドです。
      技術と感性、そして人と人との繋がりを大切に、それぞれの島で確かなコミュニティを育んでいます。
      私たちと一緒に、お客様の人生に寄り添う美容師として歩んでくれる仲間を募集しています。
    </p>
  </section>

  <section class="recruit-positions">
    {positions.map((p, i) => (
      <article class="position">
        <p class="position__label">/ {String(i + 1).padStart(2, "0")} &nbsp; {p.label}</p>
        <h2 class="position__title">{p.title}</h2>
        <p class="position__desc">{p.desc}</p>
        <dl class="position__meta">
          <div>
            <dt>Locations</dt>
            <dd>{p.target.join(" / ")}</dd>
          </div>
          <div>
            <dt>Inquiry</dt>
            <dd><a href={`mailto:${site.contactEmail}?subject=採用：${p.title}`}>{site.contactEmail}</a></dd>
          </div>
        </dl>
      </article>
    ))}
  </section>
</BaseLayout>

<style>
  .recruit-intro {
    padding: 110px 32px 80px;
    max-width: 900px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
    text-align: center;
  }
  .recruit-intro__lede {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(28px, 4vw, 48px);
    line-height: 1.3;
    text-transform: uppercase;
    margin: 0 0 32px;
  }
  .recruit-intro__lede em {
    font-style: italic;
  }
  .recruit-intro__text {
    font-size: 15px;
    line-height: 2;
    color: var(--color-fg-muted);
    max-width: 640px;
    margin: 0 auto;
    text-align: left;
  }

  .recruit-positions {
    padding: 60px 32px 140px;
    max-width: 1100px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
    border-top: 1px solid var(--color-border);
  }
  .position {
    padding: 56px 0;
    border-bottom: 1px solid var(--color-border);
    display: grid;
    grid-template-columns: 1fr 1.5fr;
    gap: 48px;
    align-items: baseline;
  }
  @media (max-width: 700px) {
    .position { grid-template-columns: 1fr; gap: 18px; }
  }
  .position__label {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--color-fg-muted);
    margin: 0;
  }
  .position__title {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(24px, 3vw, 36px);
    line-height: 1.3;
    margin: 0 0 18px;
  }
  .position__desc {
    font-size: 15px;
    line-height: 1.95;
    color: var(--color-fg-muted);
    margin: 0 0 32px;
  }
  .position__meta {
    margin: 0;
    border-top: 1px solid var(--color-border);
  }
  .position__meta > div {
    display: grid;
    grid-template-columns: 110px 1fr;
    gap: 24px;
    padding: 14px 0;
    border-bottom: 1px solid var(--color-border);
    align-items: baseline;
  }
  .position__meta dt {
    font-family: var(--font-mono);
    font-size: 10.5px;
    letter-spacing: 0.26em;
    text-transform: uppercase;
    color: var(--color-fg-muted);
    margin: 0;
  }
  .position__meta dd {
    font-size: 14px;
    margin: 0;
  }
  .position__meta a {
    border-bottom: 1px solid var(--color-fg);
    padding-bottom: 1px;
  }
</style>
