---
import BaseLayout from "~layouts/BaseLayout.astro";
import PageHero from "~components/PageHero.astro";
import Picture from "~components/Picture.astro";
import { breadcrumbSchema, jsonLd } from "~lib/schema";
import { brandLabel } from "~lib/brand";
import { site } from "~data/site";
import { salons } from "~data/salons";

const description = `iLe（${site.companyName}）の採用情報。美容師（スタイリスト・アシスタント）、新卒採用を募集。エフェクトブリーチを開発した技術集団のもと、原宿・名古屋・長岡の4店舗で共に島をつくる仲間を募集しています。`;

// Facts only — no invented salary/benefit figures. Conditions are
// explained at the interview (待遇は面談で説明), per brand-brief rules.
const stats = [
  { n: "2020", label: "EST. HARAJUKU" },
  { n: "4", label: "SALONS" },
  { n: "3", label: "CITIES — 東京・名古屋・長岡" },
  { n: "32", label: "MEMBERS" },
];

const pillars = [
  {
    label: "Technique",
    title: "「エフェクトブリーチ」を生んだ技術集団",
    body:
      "iLe の看板技術・エフェクトブリーチは、共同代表の酒井元樹が開発したもの。ダメージ履歴を10段階で診断し、過酸化水素の濃度をミリ単位で調整する「パーソナル減力」——その理論を、開発者本人のそばで学べる環境です。共同代表の二人は共著『複雑履歴のブリーチ大全』（髪書房）を持ち、美容師向けセミナーの講師も務めるいわば“プロを教えるプロ”。ブリーチ・デザインカラーを本気で極めたい人にとって、これ以上ない教科書が隣にいます。",
    links: [
      { href: "/effect-bleach", label: "エフェクトブリーチ" },
      { href: "/expertise", label: "技術と専門性" },
    ],
  },
  {
    label: "Growth",
    title: "船を出し、島を増やしてきたブランド",
    body:
      "2020年に原宿で生まれた iLe は、原宿2店舗目、そして2025年には長岡・名古屋と、6年で4つの島に育ちました。2026年8月1日にはすべての店舗が「iLe」ブランドに統一され、新しい章が始まります。店舗が増え、ブランドが広がるということは、新しいポジションと役割が生まれ続けるということ。成長の途中にあるブランドだからこそ、あなたの挑戦できる余白があります。",
    links: [{ href: "/story", label: "船から、島へ — Story" }],
  },
  {
    label: "Places",
    title: "東京・名古屋・長岡 — 3つの街、同じ基準",
    body:
      "原宿で磨かれた技術と美意識を、名古屋・長岡でも同じ基準で。都心でキャリアを積むことも、地元で最先端の技術に触れることも、iLe なら選べます。全店舗のスタイリストが同じ技術体系を共有しているから、店舗を越えた学び合いがあります。",
    links: [{ href: "/salons", label: "店舗一覧" }],
  },
];

const positions = [
  {
    id: "stylist",
    label: "Stylist",
    title: "美容師（スタイリスト）",
    desc:
      "技術と感性を活かして、お客様一人ひとりの「なりたい」に寄り添えるスタイリストを募集しています。ブリーチ・デザインカラーの技術をさらに磨きたい方、エフェクトブリーチを本場で学びたい方を歓迎します。",
    requirements: "美容師免許をお持ちの方（スタイリスト経験者歓迎）",
    locations: "原宿（×2）/ 名古屋 / 長岡",
  },
  {
    id: "assistant",
    label: "Assistant",
    title: "美容師（アシスタント）",
    desc:
      "iLe の島づくりを支える、技術と心を磨くアシスタントを募集しています。エフェクトブリーチの理論を基礎から体系立てて学び、スタイリストデビューを目指せる環境です。",
    requirements: "美容師免許をお持ちの方（取得見込みを含む）",
    locations: "原宿（×2）/ 名古屋 / 長岡",
  },
  {
    id: "newgrad",
    label: "New Grad",
    title: "新卒採用",
    desc:
      "美容専門学校を卒業予定の方を対象とした新卒採用。サロンワークの基礎から、iLe Academy に体系化された技術理論まで、一歩ずつ確実に学べます。「どの街で働くか」も含めて、あなたの island を一緒に探しましょう。",
    requirements: "美容師免許 取得見込みの方（美容専門学校 卒業見込み）",
    locations: "全店舗（原宿 / 名古屋 / 長岡）",
  },
];

const steps = [
  {
    n: "01",
    title: "応募・お問い合わせ",
    body: "メールに、お名前・希望職種・希望店舗（未定でも構いません）を添えてご連絡ください。ポートフォリオや Instagram アカウントがあれば、ぜひ一緒に。",
  },
  {
    n: "02",
    title: "面談・サロン見学",
    body: "店舗の空気を感じてもらいながら、これまでのことと、これからやりたいことを聞かせてください。給与・待遇などの条件も、このときに詳しくご説明します。",
  },
  {
    n: "03",
    title: "合流",
    body: "あなたの島での新しい章が始まります。",
  },
];

const mailSubject = encodeURIComponent("採用応募：");
const heroSalon = salons[0];

const jobPostingSchemas = positions.map((p) => ({
  "@context": "https://schema.org",
  "@type": "JobPosting",
  title: p.title,
  description: `${p.desc} 応募資格: ${p.requirements}。勤務地: ${p.locations}。給与・待遇は面談時にご説明します。`,
  datePosted: "2026-07-02",
  hiringOrganization: { "@id": `${site.url}/#organization` },
  industry: "美容業",
  jobLocation: salons.map((s) => ({
    "@type": "Place",
    name: s.nameLatin,
    address: {
      "@type": "PostalAddress",
      streetAddress: s.address,
      addressCountry: "JP",
    },
  })),
  applicationContact: {
    "@type": "ContactPoint",
    email: site.contactEmail,
  },
  directApply: true,
}));

const pageSchemas = [
  breadcrumbSchema([
    { name: "Home", url: "/" },
    { name: "Recruit", url: "/recruit" },
  ]),
  ...jobPostingSchemas,
];
---

<BaseLayout title="Recruit — 採用情報" description={description}>
  <Fragment slot="head">
    {pageSchemas.map((schema) => (
      <script type="application/ld+json" set:html={jsonLd(schema)} is:inline />
    ))}
  </Fragment>

  <PageHero
    eyebrow="— Join the Island"
    title="RECRUIT"
    italicTitle="Island"
  />

  <!-- Intro -->
  <section class="recruit-intro">
    <p class="recruit-intro__lede">
      次の島を、<em>あなた</em>と。
    </p>
    <p class="recruit-intro__text">
      iLe は、原宿・名古屋・長岡で美容室4店舗を運営する株式会社ing のブランドです。
      2020年、原宿の小さな一店舗から始まり、船を出すように仲間と土地を増やしてきました。
      2026年8月1日、すべての店舗が「iLe」に統一され、新しい章が始まります。
      その章を一緒に書いてくれる美容師を、私たちは探しています。
    </p>

    <ul class="recruit-stats" aria-label="iLe の概要">
      {stats.map((s) => (
        <li class="recruit-stats__item">
          <span class="recruit-stats__n">{s.n}</span>
          <span class="recruit-stats__label">{s.label}</span>
        </li>
      ))}
    </ul>
  </section>

  <!-- Atmosphere band -->
  <div class="recruit-band" aria-hidden="true">
    <Picture
      class="recruit-band__img"
      src={heroSalon.heroImage!.url}
      width={heroSalon.heroImage!.width}
      height={heroSalon.heroImage!.height}
      alt=""
      loading="lazy"
    />
  </div>

  <!-- Why iLe -->
  <section class="recruit-why">
    <h2 class="recruit-h2">Why <em>iLe</em></h2>
    <div class="recruit-why__list">
      {pillars.map((p, i) => (
        <article class="pillar">
          <p class="pillar__label">/ {String(i + 1).padStart(2, "0")} &nbsp; {p.label}</p>
          <h3 class="pillar__title">{p.title}</h3>
          <p class="pillar__body">{p.body}</p>
          <div class="pillar__links">
            {p.links.map((l) => (
              <a href={l.href}>{l.label} →</a>
            ))}
          </div>
        </article>
      ))}
    </div>
  </section>

  <!-- Academy -->
  <section class="recruit-academy">
    <div class="recruit-academy__inner">
      <p class="recruit-academy__eyebrow">— Education</p>
      <h2 class="recruit-academy__h" set:html={brandLabel("iLe Academy")} />
      <p class="recruit-academy__text">
        エフェクトブリーチの理論は、<strong>iLe Academy</strong> として体系化され、全国の美容師にも開かれています。
        社内では、その基礎から実践までを段階立てて学べる——つまり、外部の美容師が学びに来る内容を、
        毎日の現場で吸収できるということ。国内外で講師を務める共同代表・酒井元樹と西村涼、
        そして各店舗の先輩スタイリストが、あなたの技術の土台をつくります。
      </p>
    </div>
  </section>

  <!-- Positions -->
  <section class="recruit-positions" id="positions">
    <h2 class="recruit-h2">Open <em>Positions</em></h2>
    {positions.map((p, i) => (
      <article class="position" id={p.id}>
        <p class="position__label">/ {String(i + 1).padStart(2, "0")} &nbsp; {p.label}</p>
        <div>
          <h3 class="position__title">{p.title}</h3>
          <p class="position__desc">{p.desc}</p>
          <dl class="position__meta">
            <div>
              <dt>応募資格</dt>
              <dd>{p.requirements}</dd>
            </div>
            <div>
              <dt>勤務地</dt>
              <dd>{p.locations}</dd>
            </div>
            <div>
              <dt>給与・待遇</dt>
              <dd>経験・スキルを考慮のうえ決定します（面談時に詳しくご説明します）</dd>
            </div>
          </dl>
          <a
            class="position__apply"
            href={`mailto:${site.contactEmail}?subject=${mailSubject}${encodeURIComponent(p.title)}`}
          >
            この職種に応募する →
          </a>
        </div>
      </article>
    ))}
  </section>

  <!-- Flow -->
  <section class="recruit-flow">
    <h2 class="recruit-h2">応募の<em>流れ</em></h2>
    <ol class="recruit-flow__list">
      {steps.map((s) => (
        <li class="flow-step">
          <p class="flow-step__n">{s.n}</p>
          <h3 class="flow-step__title">{s.title}</h3>
          <p class="flow-step__body">{s.body}</p>
        </li>
      ))}
    </ol>
    <p class="recruit-flow__note">
      働く人・店舗の雰囲気は
      <a href="/stylists">スタイリスト一覧</a>や
      Instagram（<a href={`https://instagram.com/${site.instagramHandle}`} target="_blank" rel="noopener">@{site.instagramHandle}</a>）でもご覧いただけます。
      よくあるご質問は <a href="/faq">FAQ</a> へ。
    </p>
  </section>

  <!-- CTA -->
  <section class="recruit-cta">
    <p class="recruit-cta__lede">共に、<em>島</em>をつくる。</p>
    <a
      class="recruit-cta__btn"
      href={`mailto:${site.contactEmail}?subject=${mailSubject}`}
    >
      {site.contactEmail} →
    </a>
    <p class="recruit-cta__sub">
      迷っている段階のご相談・サロン見学だけでも歓迎します。
    </p>
  </section>
</BaseLayout>

<style>
  .recruit-h2 {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(30px, 4.5vw, 52px);
    line-height: 1.15;
    text-transform: uppercase;
    margin: 0 0 56px;
  }
  .recruit-h2 em {
    font-style: italic;
  }

  /* Intro */
  .recruit-intro {
    padding: 110px 32px 90px;
    max-width: 980px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
    text-align: center;
  }
  .recruit-intro__lede {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(30px, 4.5vw, 52px);
    line-height: 1.3;
    margin: 0 0 32px;
  }
  .recruit-intro__lede em {
    font-style: italic;
  }
  .recruit-intro__text {
    font-size: 15px;
    line-height: 2.1;
    color: var(--color-fg-muted);
    max-width: 660px;
    margin: 0 auto;
    text-align: left;
  }
  .recruit-stats {
    list-style: none;
    padding: 0;
    margin: 72px 0 0;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }
  @media (max-width: 700px) {
    .recruit-stats {
      grid-template-columns: repeat(2, 1fr);
    }
    .recruit-stats__item:nth-child(-n + 2) {
      border-bottom: 1px solid var(--color-border);
    }
  }
  .recruit-stats__item {
    padding: 28px 12px;
  }
  .recruit-stats__item:not(:first-child) {
    border-left: 1px solid var(--color-border);
  }
  @media (max-width: 700px) {
    .recruit-stats__item:nth-child(3) {
      border-left: 0;
    }
  }
  .recruit-stats__n {
    display: block;
    font-family: var(--font-display);
    font-size: clamp(30px, 4vw, 46px);
    line-height: 1;
    margin: 0 0 10px;
  }
  .recruit-stats__label {
    display: block;
    font-family: var(--font-mono);
    font-size: 9.5px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-fg-muted);
  }

  /* Atmosphere band */
  .recruit-band {
    position: relative;
    z-index: 1;
    max-height: 420px;
    overflow: hidden;
    background: var(--color-ink);
  }
  .recruit-band :global(.recruit-band__img) {
    display: block;
    width: 100%;
    height: auto;
    filter: grayscale(100%);
  }

  /* Why */
  .recruit-why {
    padding: 110px 32px 60px;
    max-width: 1100px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }
  .pillar {
    padding: 52px 0;
    border-top: 1px solid var(--color-border);
    display: grid;
    grid-template-columns: 220px 1fr;
    column-gap: 32px;
  }
  @media (max-width: 760px) {
    .pillar {
      grid-template-columns: 1fr;
    }
  }
  .pillar__label {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--color-fg-muted);
    margin: 6px 0 14px;
    grid-column: 1;
  }
  .pillar__title {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(21px, 2.6vw, 30px);
    line-height: 1.4;
    margin: 0 0 16px;
    grid-column: 2;
    grid-row: 1;
  }
  .pillar__body {
    font-size: 14.5px;
    line-height: 2.05;
    color: var(--color-fg-muted);
    margin: 0 0 20px;
    grid-column: 2;
    max-width: 640px;
  }
  .pillar__links {
    grid-column: 2;
    display: flex;
    flex-wrap: wrap;
    gap: 10px 22px;
  }
  @media (max-width: 760px) {
    .pillar__title,
    .pillar__body,
    .pillar__links {
      grid-column: 1;
      grid-row: auto;
    }
  }
  .pillar__links a {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    border-bottom: 1px solid var(--color-fg);
    padding-bottom: 2px;
  }

  /* Academy */
  .recruit-academy {
    background: var(--color-ink);
    color: var(--color-white);
    padding: 110px 32px;
    position: relative;
    z-index: 1;
  }
  .recruit-academy__inner {
    max-width: 820px;
    margin: 0 auto;
    text-align: center;
  }
  .recruit-academy__eyebrow {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--color-fg-on-dark-muted);
    margin: 0 0 18px;
  }
  .recruit-academy__h {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(32px, 5vw, 58px);
    line-height: 1.1;
    text-transform: uppercase;
    margin: 0 0 30px;
  }
  .recruit-academy__text {
    font-size: 14.5px;
    line-height: 2.15;
    color: rgba(255, 255, 255, 0.78);
    margin: 0;
    text-align: left;
  }

  /* Positions */
  .recruit-positions {
    padding: 110px 32px 40px;
    max-width: 1100px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }
  .position {
    padding: 56px 0;
    border-top: 1px solid var(--color-border);
    display: grid;
    grid-template-columns: 220px 1fr;
    gap: 32px;
  }
  @media (max-width: 760px) {
    .position {
      grid-template-columns: 1fr;
      gap: 16px;
    }
  }
  .position__label {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--color-fg-muted);
    margin: 6px 0 0;
  }
  .position__title {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(24px, 3vw, 36px);
    line-height: 1.3;
    margin: 0 0 18px;
  }
  .position__desc {
    font-size: 14.5px;
    line-height: 2;
    color: var(--color-fg-muted);
    margin: 0 0 30px;
    max-width: 640px;
  }
  .position__meta {
    margin: 0 0 32px;
    border-top: 1px solid var(--color-border);
    max-width: 640px;
  }
  .position__meta > div {
    display: grid;
    grid-template-columns: 110px 1fr;
    gap: 24px;
    padding: 14px 0;
    border-bottom: 1px solid var(--color-border);
    align-items: baseline;
  }
  .position__meta dt {
    font-family: var(--font-mono);
    font-size: 10.5px;
    letter-spacing: 0.22em;
    color: var(--color-fg-muted);
    margin: 0;
  }
  .position__meta dd {
    font-size: 13.5px;
    line-height: 1.8;
    margin: 0;
  }
  .position__apply {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 11.5px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    border: 1px solid var(--color-ink);
    padding: 15px 30px;
    transition: background 0.2s, color 0.2s;
  }
  .position__apply:hover {
    background: var(--color-ink);
    color: var(--color-white);
  }

  /* Flow */
  .recruit-flow {
    padding: 90px 32px 100px;
    max-width: 1100px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }
  .recruit-flow__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px;
  }
  @media (max-width: 760px) {
    .recruit-flow__list {
      grid-template-columns: 1fr;
    }
  }
  .flow-step {
    border: 1px solid var(--color-border);
    padding: 32px 26px;
    background: var(--color-snow);
  }
  .flow-step__n {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 20px;
    color: var(--color-ash);
    margin: 0 0 16px;
  }
  .flow-step__title {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: 19px;
    margin: 0 0 12px;
  }
  .flow-step__body {
    font-size: 13.5px;
    line-height: 1.95;
    color: var(--color-fg-muted);
    margin: 0;
  }
  .recruit-flow__note {
    margin: 44px 0 0;
    font-size: 13.5px;
    line-height: 2;
    color: var(--color-fg-muted);
  }
  .recruit-flow__note a {
    border-bottom: 1px solid currentColor;
  }

  /* CTA */
  .recruit-cta {
    background: var(--color-pearl);
    text-align: center;
    padding: 90px 32px 130px;
    position: relative;
    z-index: 1;
  }
  .recruit-cta__lede {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(28px, 4vw, 44px);
    margin: 0 0 30px;
  }
  .recruit-cta__lede em {
    font-style: italic;
  }
  .recruit-cta__btn {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 12.5px;
    letter-spacing: 0.18em;
    border: 1px solid var(--color-ink);
