---
import BaseLayout from "~layouts/BaseLayout.astro";
import Hero from "~components/Hero.astro";
import Statement from "~components/Statement.astro";
import SectionHead from "~components/SectionHead.astro";
import SalonRow from "~components/SalonRow.astro";
import StylistCard from "~components/StylistCard.astro";
import InfoStrip from "~components/InfoStrip.astro";
import JournalCard from "~components/JournalCard.astro";
import Ticker from "~components/Ticker.astro";

import { salons } from "~data/salons";
import { stylists } from "~data/stylists";
import { journalPosts } from "~data/journal";

import {
  personFounderSchema,
  localBusinessSchema,
  breadcrumbSchema,
  jsonLd,
} from "~lib/schema";

// LLMO: page-specific JSON-LD
const pageSchemas = [
  personFounderSchema(),
  ...salons.map(localBusinessSchema),
  breadcrumbSchema([{ name: "Home", url: "/" }]),
];
---

<BaseLayout
  title="船から、島へ。"
  description="iLe｜美容室 — 原宿・名古屋・長岡。2020年に原宿で創業した株式会社ingは、2026年8月1日、運営する4店舗（旧 iLe / nehus）すべてを iLe ブランドに統一します。"
>
  <Fragment slot="head">
    {pageSchemas.map((schema) => (
      <script type="application/ld+json" set:html={jsonLd(schema)} is:inline />
    ))}
  </Fragment>

  <Hero />

  <Statement />

  <section class="section section--salons" aria-labelledby="salons-h">
    <div id="salons-h">
      <SectionHead small="— The Four Islands" title="Salons" />
    </div>
    {salons.map((salon, i) => (
      <SalonRow salon={salon} reverse={i % 2 === 1} />
    ))}
  </section>

  <section class="section section--stylists" aria-labelledby="stylists-h">
    <div id="stylists-h">
      <SectionHead small="— The Hands Behind" title="Stylists" />
    </div>
    <div class="stylists-grid">
      {stylists.map((stylist, i) => (
        <StylistCard stylist={stylist} index={i} />
      ))}
    </div>
  </section>

  <InfoStrip />

  <section class="section section--journal" aria-labelledby="journal-h">
    <div id="journal-h">
      <SectionHead small="— Updates &amp; Press" title="Journal" />
    </div>
    <div class="journal-grid">
      {journalPosts.map((post, i) => (
        <JournalCard post={post} index={i} />
      ))}
    </div>
  </section>

  <Ticker />
</BaseLayout>

<style>
  .section {
    padding: 110px 32px;
    position: relative;
    z-index: 1;
  }
  .section--stylists {
    background: var(--color-pearl);
  }

  .stylists-grid {
    display: grid;
    gap: 32px 24px;
    grid-template-columns: repeat(2, 1fr);
    max-width: 1400px;
    margin: 0 auto;
  }
  @media (min-width: 700px) {
    .stylists-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
  @media (min-width: 1100px) {
    .stylists-grid {
      grid-template-columns: repeat(6, 1fr);
    }
  }

  .journal-grid {
    display: grid;
    gap: 48px;
    grid-template-columns: 1fr;
    max-width: 1400px;
    margin: 0 auto;
  }
  @media (min-width: 900px) {
    .journal-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
