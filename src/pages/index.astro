---
import BaseLayout from "~layouts/BaseLayout.astro";
import Hero from "~components/Hero.astro";
import Statement from "~components/Statement.astro";
import SectionHead from "~components/SectionHead.astro";
import SalonCard from "~components/SalonCard.astro";
import StylistCard from "~components/StylistCard.astro";
import InfoStrip from "~components/InfoStrip.astro";
import JournalCard from "~components/JournalCard.astro";
import Ticker from "~components/Ticker.astro";

import { getSalons, getStylists, getJournalPosts } from "~lib/content";

import {
  personFounderSchema,
  localBusinessSchema,
  breadcrumbSchema,
  jsonLd,
} from "~lib/schema";
import { brandLabel } from "~lib/brand";

const salons = await getSalons();
const stylists = await getStylists();
const journalPosts = await getJournalPosts();

// Staff listing excludes the co-representatives (featured separately on
// /expertise, /message), grouped by store.
const reps = stylists.filter((s) => s.position === "共同代表");
const staff = stylists.filter((s) => s.position !== "共同代表");
const stylistGroups = salons.map((salon) => ({
  salon,
  // Photo-less staff are grouped at the very back of each salon.
  members: staff
    .filter((s) => s.salonSlug === salon.slug)
    .sort((a, b) => (a.portrait ? 0 : 1) - (b.portrait ? 0 : 1)),
}));

// LLMO: page-specific JSON-LD
const pageSchemas = [
  personFounderSchema(),
  ...salons.map(localBusinessSchema),
  breadcrumbSchema([{ name: "Home", url: "/" }]),
];
---

<BaseLayout
  title="船から、島へ。"
  description="iLe｜美容室 — 原宿・名古屋・長岡。2020年に原宿で創業した株式会社ingは、2026年8月1日、運営する4店舗（旧 iLe / nehus）すべてを iLe ブランドに統一します。"
>
  <Fragment slot="head">
    {pageSchemas.map((schema) => (
      <script type="application/ld+json" set:html={jsonLd(schema)} is:inline />
    ))}
  </Fragment>

  <h1 class="sr-only">iLe｜美容室 — 原宿・名古屋・長岡。船から、島へ。</h1>

  <Hero />

  <Statement />

  <section class="section section--salons" aria-labelledby="salons-h">
    <div id="salons-h">
      <SectionHead small="— The Four Islands" title="Salons" />
    </div>
    <div class="salons-grid">
      {salons.map((salon) => (
        <SalonCard salon={salon} />
      ))}
    </div>
  </section>

  <section class="section section--stylists" aria-labelledby="stylists-h">
    <div id="stylists-h">
      <SectionHead small="— The Hands Behind" title="Stylists" />
    </div>
    {reps.length > 0 && (
      <div class="stylists-store stylists-store--reps">
        <h3 class="stylists-store__h">
          <span class="stylists-store__num">/ 00</span>
          Co-Representatives
          <span class="stylists-store__city">— <Fragment set:html={brandLabel("iLe")} /></span>
        </h3>
        <div class="stylists-grid">
          {reps.map((stylist, i) => (
            <StylistCard stylist={stylist} index={i} />
          ))}
        </div>
      </div>
    )}
    {stylistGroups.map(({ salon, members }, gi) => members.length > 0 && (
      <div class="stylists-store">
        <h3 class="stylists-store__h">
          <span class="stylists-store__num">/ {salon.number}</span>
          <Fragment set:html={brandLabel(salon.nameLatin)} />
          <span class="stylists-store__city">— {salon.cityShort}</span>
        </h3>
        <div class="stylists-grid">
          {members.map((stylist, i) => (
            <StylistCard stylist={stylist} index={gi * 6 + i} />
          ))}
        </div>
      </div>
    ))}
    <p class="stylists-all">
      <a href="/stylists">View all stylists →</a>
    </p>
  </section>

  <InfoStrip />

  <section class="section section--journal" aria-labelledby="journal-h">
    <div id="journal-h">
      <SectionHead small="— Updates &amp; Press" title="Journal" />
    </div>
    <div class="journal-grid">
      {journalPosts.map((post, i) => (
        <JournalCard post={post} index={i} />
      ))}
    </div>
  </section>

  <Ticker />
</BaseLayout>

<style>
  .section {
    padding: 110px 32px;
    position: relative;
    z-index: 1;
  }
  .section--stylists {
    background: var(--color-pearl);
  }

  .salons-grid {
    max-width: 1180px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr;
    gap: 56px 48px;
  }
  @media (min-width: 760px) {
    .salons-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .stylists-store {
    max-width: 1400px;
    margin: 0 auto 80px;
  }
  .stylists-store:last-of-type {
    margin-bottom: 56px;
  }
  .stylists-store__h {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(22px, 3vw, 34px);
    line-height: 1;
    text-transform: uppercase;
    margin: 0 0 36px;
    display: flex;
    align-items: baseline;
    gap: 14px;
    flex-wrap: wrap;
  }
  .stylists-store__num,
  .stylists-store__city {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.26em;
    color: var(--color-fg-muted);
  }
  .stylists-all {
    max-width: 1400px;
    margin: 0 auto;
    text-align: center;
  }
  .stylists-all a {
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    border-bottom: 1px solid currentColor;
    padding-bottom: 4px;
  }
  .stylists-grid {
    display: grid;
    gap: 32px 24px;
    grid-template-columns: repeat(2, 1fr);
    max-width: 1400px;
    margin: 0 auto;
  }
  @media (min-width: 700px) {
    .stylists-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
  @media (min-width: 1100px) {
    .stylists-grid {
      grid-template-columns: repeat(6, 1fr);
    }
  }

  .journal-grid {
    display: grid;
    gap: 48px;
    grid-template-columns: 1fr;
    max-width: 1400px;
    margin: 0 auto;
  }
  @media (min-width: 900px) {
    .journal-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
