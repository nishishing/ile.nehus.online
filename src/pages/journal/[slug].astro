---
import BaseLayout from "~layouts/BaseLayout.astro";
import PageHero from "~components/PageHero.astro";
import Prose from "~components/Prose.astro";
import Picture from "~components/Picture.astro";
import { getJournalPosts } from "~lib/content";
import {
  articleSchema,
  breadcrumbSchema,
  jsonLd,
} from "~lib/schema";

export async function getStaticPaths() {
  const journalPosts = await getJournalPosts();
  return journalPosts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;

const description =
  post.summary ?? `${post.title}｜iLe Journal — ${post.publishedAtLabel}`;

const pageSchemas = [
  articleSchema(post),
  breadcrumbSchema([
    { name: "Home", url: "/" },
    { name: "Journal", url: "/journal" },
    { name: post.title, url: `/journal/${post.slug}` },
  ]),
];
---

<BaseLayout
  title={post.subtitle ? `${post.title} — ${post.subtitle}` : post.title}
  description={description}
  ogType="article"
  ogImage={post.ogImage?.url ?? post.eyecatch?.url}
>
  <Fragment slot="head">
    {pageSchemas.map((schema) => (
      <script type="application/ld+json" set:html={jsonLd(schema)} is:inline />
    ))}
  </Fragment>

  <PageHero
    eyebrow={`— ${post.categoryLabel} / ${post.publishedAtLabel}`}
    title={post.title.toUpperCase()}
  />

  {post.eyecatch?.url && (
    <figure class="journal-eyecatch">
      <Picture
        class="journal-eyecatch__img"
        src={post.eyecatch.url}
        width={post.eyecatch.width}
        height={post.eyecatch.height}
        alt={post.eyecatchAlt ?? post.title}
        loading="eager"
      />
    </figure>
  )}

  <article class="journal-article">
    <Prose>
      {post.subtitle && <p class="lead">{post.subtitle}</p>}
      {post.summary && <p>{post.summary}</p>}
      {post.body && <div set:html={post.body} />}
    </Prose>
  </article>
</BaseLayout>

<style>
  .journal-eyecatch {
    margin: 0;
    position: relative;
    z-index: 1;
    background: var(--color-ink);
  }
  .journal-eyecatch :global(.journal-eyecatch__img) {
    display: block;
    width: 100%;
    max-height: 70vh;
    object-fit: cover;
  }
  .journal-article {
    padding: 110px 32px 140px;
    position: relative;
    z-index: 1;
  }
  /* When an eyecatch precedes the article, tighten the top padding a touch. */
  .journal-eyecatch + .journal-article {
    padding-top: 80px;
  }
</style>
