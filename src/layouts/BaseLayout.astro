---
import BaseHead from "~components/BaseHead.astro";
import LanguageStrip from "~components/LanguageStrip.astro";
import Header from "~components/Header.astro";
import Footer from "~components/Footer.astro";
import Floating from "~components/Floating.astro";
import { getJournalPosts } from "~lib/content";

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  ogType?: "website" | "article";
  noindex?: boolean;
  hideFloating?: boolean;
}

const {
  title,
  description,
  ogImage,
  ogType,
  noindex,
  hideFloating = false,
} = Astro.props;

// Floating CTA features the most recent journal post (same ordering as /journal).
const latestPost = hideFloating
  ? null
  : ([...(await getJournalPosts())].sort((a, b) =>
      b.publishedAt.localeCompare(a.publishedAt),
    )[0] ?? null);
---

<!doctype html>
<html lang="ja">
  <head>
    <BaseHead
      title={title}
      description={description}
      ogImage={ogImage}
      ogType={ogType}
      noindex={noindex}
    />
    <slot name="head" />
  </head>
  <body>
    <a href="#main" class="skip-link">本文へスキップ</a>
    <LanguageStrip />
    <Header />
    <main id="main" tabindex="-1">
      <slot />
    </main>
    <Footer />
    {latestPost && <Floating post={latestPost} />}
  </body>
</html>
