---
import BaseHead from "~components/BaseHead.astro";
import LanguageStrip from "~components/LanguageStrip.astro";
import AnnounceBar from "~components/AnnounceBar.astro";
import Header from "~components/Header.astro";
import Footer from "~components/Footer.astro";
import Floating from "~components/Floating.astro";
import { getJournalPosts } from "~lib/content";

// Cloudflare Web Analytics (cookieless). Emitted only when the token is
// provided at build time — set PUBLIC_CF_BEACON_TOKEN in the Cloudflare
// build settings (Workers & Pages → Settings → Variables) to enable.
const cfBeaconToken = import.meta.env.PUBLIC_CF_BEACON_TOKEN as
  | string
  | undefined;

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  ogType?: "website" | "article";
  noindex?: boolean;
  hideFloating?: boolean;
}

const {
  title,
  description,
  ogImage,
  ogType,
  noindex,
  hideFloating = false,
} = Astro.props;

// Floating CTA features the most recent journal post (same ordering as /journal).
const latestPost = hideFloating
  ? null
  : ([...(await getJournalPosts())].sort((a, b) =>
      b.publishedAt.localeCompare(a.publishedAt),
    )[0] ?? null);
---

<!doctype html>
<html lang="ja">
  <head>
    <BaseHead
      title={title}
      description={description}
      ogImage={ogImage}
      ogType={ogType}
      noindex={noindex}
    />
    <slot name="head" />
    {cfBeaconToken && (
      <script
        is:inline
        defer
        src="https://static.cloudflareinsights.com/beacon.min.js"
        data-cf-beacon={JSON.stringify({ token: cfBeaconToken })}
      ></script>
    )}
  </head>
  <body>
    <a href="#main" class="skip-link">本文へスキップ</a>
    <AnnounceBar />
    <LanguageStrip />
    <Header />
    <main id="main" tabindex="-1">
      <slot />
    </main>
    <Footer />
    {latestPost && <Floating post={latestPost} />}
  </body>
</html>
