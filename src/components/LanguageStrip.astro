---
import { languages } from "~data/site";
---

<div class="lang-strip">
  {languages.map((lang) =>
    lang.current ? (
      <span class="lang-strip__current" aria-current="true">{lang.code}</span>
    ) : lang.available ? (
      <a class="lang-strip__link" href={lang.href} aria-label={`Switch to ${lang.code}`}>
        {lang.code}
      </a>
    ) : (
      <span
        class="lang-strip__soon"
        aria-disabled="true"
        title={`${lang.code} — coming soon`}
      >
        {lang.code}
      </span>
    ),
  )}
</div>

<style>
  .lang-strip {
    position: fixed;
    top: var(--announce-h);
    right: 0;
    z-index: 60;
    padding: 16px 22px;
    display: flex;
    gap: 12px;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.18em;
    color: var(--color-fg-on-dark-muted);
    /* Overlays the header's right edge — never swallow clicks meant for
       the BOOK link / menu button beneath. Real links re-enable below. */
    pointer-events: none;
  }
  .lang-strip a {
    pointer-events: auto;
  }
  /* On phones the strip (JP + 3 "coming soon" placeholders) is decorative
     and crowds out the menu button — hide it. */
  @media (max-width: 768px) {
    .lang-strip {
      display: none;
    }
  }
  .lang-strip__current {
    color: var(--color-white);
  }
  .lang-strip__link {
    color: var(--color-fg-on-dark-muted);
    transition: color 0.15s;
  }
  .lang-strip__link:hover {
    color: var(--color-white);
  }
  .lang-strip__soon {
    color: var(--color-fg-on-dark-muted);
    opacity: 0.45;
    cursor: not-allowed;
  }
</style>
