---
/**
 * BrandMark — the official "iLe." logo lockup.
 *
 * Reproduces the supplied vector logo (`ile.svg`): a thin double-framed
 * square with the wordmark set in Neue Haas Grotesk Display Pro. The real
 * font isn't web-available, so we fall back to its Helvetica family
 * (Helvetica Neue / Helvetica / Arial), which is metrically very close.
 *
 * Strokes + text use `currentColor`, so the parent's text color drives it
 * (white on the dark header / footer). `size` is the outer edge in px.
 */
interface Props {
  size?: number;
  class?: string;
}
const { size = 46, class: className } = Astro.props;
---

<svg
  class:list={["brand-mark", className]}
  style={`width:${size}px`}
  viewBox="183 443 572 545"
  role="img"
  aria-label="iLe"
  xmlns="http://www.w3.org/2000/svg"
>
  <!-- outer + inner frame (official coords) -->
  <rect x="189.74" y="449.5" width="558.48" height="531" fill="none" stroke="currentColor" stroke-width="3" />
  <rect x="198.5" y="457.5" width="541" height="515" fill="none" stroke="currentColor" stroke-width="3" opacity="0.45" />
  <text
    transform="translate(399 768.96) scale(.96 1)"
    font-family="'Helvetica Neue', Helvetica, Arial, sans-serif"
    font-size="96.67"
    letter-spacing="2.9"
    fill="currentColor"
  >iLe.</text>
</svg>

<style>
  .brand-mark {
    display: block;
    height: auto;
  }
</style>
