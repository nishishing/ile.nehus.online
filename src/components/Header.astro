---
import { navPrimary } from "~data/site";
import BrandMark from "~components/BrandMark.astro";
---

<header class="header">
  <a class="header__logo" href="/" aria-label="iLe — home">
    <BrandMark size={46} />
  </a>
  <nav class="header__nav" aria-label="Primary">
    <ul>
      {navPrimary.map((item) => (
        <li><a href={item.href} set:html={item.label} /></li>
      ))}
    </ul>
  </nav>
  <div class="header__right">
    <a href="/salons" class="header__action">BOOK</a>
  </div>
</header>

<style>
  .header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 50;
    padding: 24px 32px;
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 48px;
    color: var(--color-white);
  }
  .header__logo {
    display: inline-flex;
    line-height: 0;
  }
  .header__nav ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    gap: 32px;
    font-family: var(--font-mono);
    font-size: 11.5px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
  }
  .header__nav a {
    transition: opacity 0.15s;
  }
  .header__nav a:hover {
    opacity: 0.7;
  }
  .header__right {
    display: flex;
    gap: 22px;
    align-items: center;
    padding-right: 80px; /* space for language strip */
    font-family: var(--font-mono);
    font-size: 11.5px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
  }

  @media (max-width: 768px) {
    .header {
      gap: 16px;
      padding: 18px 20px;
    }
    .header__nav {
      display: none;
    }
    .header__right {
      padding-right: 64px;
    }
  }
</style>
